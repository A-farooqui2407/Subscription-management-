# Server — Phase 1
# NODE_ENV: use "development" for verbose errors (e.g. stack in API responses); "production" to hide stacks
NODE_ENV=development
# Demo without DB: true = skip startup DB check and /health authenticate (see server/server.js, server/app.js)
SKIP_DB_CHECK=false
# Set to true to log SQL via logger.debug (see server/config/db.js)
DEBUG_SQL=false
# API_PREFIX: mount path for REST routes (see server/app.js)
API_PREFIX=/api
PORT=3000

# JWT (Phase 2)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL — use either DATABASE_URL or discrete vars
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subscription_management
DB_USER=postgres
DB_PASSWORD=postgres

# Email / nodemailer (Phase 2 reset password)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address for outbound mail (password reset, etc.)
SMTP_FROM=noreply@example.com
EMAIL_FROM=noreply@example.com

# Frontend base URL for password reset links: {FRONTEND_URL}/reset-password/{token}
FRONTEND_URL=http://localhost:5173

# Legacy / alternate public URL (optional)
APP_PUBLIC_URL=http://localhost:3000

# CORS (Phase 10)
CORS_ORIGIN=http://localhost:5173
